// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  DG
  DIRECTEUR
  CHEF_SERVICE
  MANAGER
  EMPLOYE
}

enum TypePeriode {
  MENSUEL
  TRIMESTRIEL
  SEMESTRIEL
}

enum StatutPeriode {
  A_VENIR
  EN_COURS
  CLOTUREE
}

enum TypeKpi {
  QUANTITATIF
  QUALITATIF
  COMPORTEMENTAL
}

enum ModeAgregation {
  CUMUL
  MOYENNE
  DERNIER
}

enum CategorieKpi {
  STRATEGIQUE
  OPERATIONNEL
}

enum FrequenceKpi {
  MENSUELLE
  TRIMESTRIELLE
  SEMESTRIELLE
  ANNUELLE
  EVENEMENTIELLE
}

enum SensCalculKpi {
  DIRECT
  PLAFOND
  ZERO_DEFAUT
  ABSOLU
}

enum StatutKpi {
  DRAFT
  ACTIF
  CLOTURE
}

enum StatutKpiEmploye {
  DRAFT
  NOTIFIE
  ACCEPTE
  CONTESTE
  MAINTENU
  REVISE
  VALIDE
  CLOTURE
}

enum StatutSaisie {
  OUVERTE
  EN_RETARD
  SOUMISE
  VALIDEE
  REJETEE
  AJUSTEE
  MANQUANTE
  VERROUILLEE
}

enum TypeNotification {
  RAPPEL_SAISIE
  SAISIE_EN_RETARD
  SAISIE_SOUMISE
  VALIDATION_REQUISE
  KPI_NOTIFIE
  KPI_CONTESTE
  KPI_MAINTENU
  KPI_REVISE
  PERIODE_CLOTUREE
}

enum PorteeKpi {
  DIRECTION
  SERVICE
  INDIVIDUEL
}

// ---------------------------------------------------------------------------
// Organisation
// ---------------------------------------------------------------------------

model Etablissement {
  id        Int         @id @default(autoincrement())
  nom       String
  logo      String?
  actif     Boolean     @default(true)
  directions Direction[]
}

model Direction {
  id              Int      @id @default(autoincrement())
  nom             String
  code            String
  description     String?
  actif           Boolean  @default(true)
  etablissementId Int
  responsableId   Int?
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id], onDelete: Cascade)
  responsable     User?    @relation("DirectionResponsable", fields: [responsableId], references: [id], onDelete: SetNull)
  users           User[]   @relation("UserDirection")
  services        Service[]
  kpiDirections  KpiDirection[]
  consolidationsDirection ConsolidationDirection[]
  catalogueKpis   DirectionCatalogueKpi[]
}

model Service {
  id            Int      @id @default(autoincrement())
  nom           String
  code          String
  description   String?
  actif         Boolean  @default(true)
  directionId   Int
  responsableId Int?
  direction     Direction @relation(fields: [directionId], references: [id], onDelete: Cascade)
  responsable   User?    @relation("ServiceResponsable", fields: [responsableId], references: [id], onDelete: SetNull)
  employes      User[]   @relation("ServiceEmployes")
  kpiServices   KpiService[]
  consolidationsService ConsolidationService[]
}

// ---------------------------------------------------------------------------
// Utilisateurs & rôles
// ---------------------------------------------------------------------------

model User {
  id                   Int       @id @default(autoincrement())
  nom                  String
  prenom               String
  email                String    @unique
  password             String
  telephone            String?
  posteOccupe          String?
  role                 Role
  actif                Boolean   @default(true)
  force_password_change Boolean  @default(false)
  emailVerified        DateTime?
  image                String?
  serviceId     Int?
  directionId   Int?
  managerId     Int?
  service       Service?  @relation("ServiceEmployes", fields: [serviceId], references: [id], onDelete: SetNull)
  direction     Direction? @relation("UserDirection", fields: [directionId], references: [id], onDelete: SetNull)
  manager       User?     @relation("Hierarchie", fields: [managerId], references: [id], onDelete: SetNull)
  collaborateurs User[]   @relation("Hierarchie")
  directionsResponsable Direction[] @relation("DirectionResponsable")
  servicesResponsable   Service[]   @relation("ServiceResponsable")
  kpiEmployesAssignes  KpiEmploye[] @relation("KpiEmployeAssignePar")
  kpiEmployesAsEmploye  KpiEmploye[] @relation("KpiEmployeEmploye")
  saisiesMensuelles    SaisieMensuelle[]
  kpiDirectionsCrees   KpiDirection[]
  kpiServicesCrees     KpiService[]
  saisiesValidees      SaisieMensuelle[] @relation("SaisieValidePar")
  saisiesDirectionValidees SaisieDirection[] @relation("SaisieDirectionValidePar")
  parametresModifies   Parametre[]
  notifications        Notification[]
  accounts             Account[]
  sessions             Session[]
  auditLogs            AuditLog[]
  saisiePeriodesOuvertesPar   SaisiePeriodeOuverte[] @relation("SaisiePeriodesOuvertesPar")
  saisiePeriodesOuvertesPour  SaisiePeriodeOuverte[] @relation("SaisiePeriodesOuvertesPour")
  directionCatalogueKpisCrees DirectionCatalogueKpi[] @relation("DirectionCatalogueKpiCreePar")
}

// ---------------------------------------------------------------------------
// Périodes
// ---------------------------------------------------------------------------

model Periode {
  id                  Int      @id @default(autoincrement())
  type                TypePeriode
  code                String
  mois_debut          Int
  mois_fin            Int
  annee               Int
  date_debut          DateTime
  date_fin            DateTime
  date_limite_saisie  DateTime
  statut              StatutPeriode
  actif               Boolean  @default(true)
  kpiDirections       KpiDirection[]
  kpiServices         KpiService[]
  kpiEmployes         KpiEmploye[]
  scorePeriodes       ScorePeriode[]
  scorePeriodesDirection ScorePeriodeDirection[]
  consolidationsService   ConsolidationService[]
  consolidationsDirection ConsolidationDirection[]
}

// ---------------------------------------------------------------------------
// Catalogue KPI
// ---------------------------------------------------------------------------

model CatalogueKpi {
  id               Int      @id @default(autoincrement())
  code             String?  @unique
  nom              String
  description      String?
  objectif_qualite String?
  formule          String?
  type             TypeKpi
  categorie        CategorieKpi?
  frequence        FrequenceKpi?
  sens_calcul      SensCalculKpi @default(DIRECT)
  unite            String?
  mode_agregation  ModeAgregation
  portee           PorteeKpi @default(INDIVIDUEL)
  actif            Boolean  @default(true)
  kpiDirections    KpiDirection[]
  kpiServices      KpiService[]
  kpiEmployes      KpiEmploye[]
  directionCatalogueKpis DirectionCatalogueKpi[]
}

model DirectionCatalogueKpi {
  id             Int          @id @default(autoincrement())
  directionId    Int
  catalogueKpiId Int
  creeParId      Int?
  createdAt      DateTime     @default(now())
  direction      Direction    @relation(fields: [directionId], references: [id], onDelete: Cascade)
  catalogueKpi   CatalogueKpi @relation(fields: [catalogueKpiId], references: [id], onDelete: Cascade)
  creePar        User?        @relation("DirectionCatalogueKpiCreePar", fields: [creeParId], references: [id], onDelete: SetNull)
  @@unique([directionId, catalogueKpiId])
  @@index([directionId])
}

// ---------------------------------------------------------------------------
// KPI Direction / Service / Employé
// ---------------------------------------------------------------------------

model KpiDirection {
  id                       Int      @id @default(autoincrement())
  catalogueKpiId            Int
  directionId               Int
  periodeId                 Int
  cible                     Float
  poids                     Float
  description_complementaire String?
  statut                    StatutKpi
  creeParId                 Int
  catalogueKpi              CatalogueKpi @relation(fields: [catalogueKpiId], references: [id], onDelete: Cascade)
  direction                 Direction    @relation(fields: [directionId], references: [id], onDelete: Cascade)
  periode                   Periode      @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  creePar                   User         @relation(fields: [creeParId], references: [id], onDelete: Restrict)
  kpiServices               KpiService[]
  saisiesDirection          SaisieDirection[]
  scorePeriodes             ScorePeriodeDirection[]
}

model KpiService {
  id                   Int      @id @default(autoincrement())
  catalogueKpiId        Int
  serviceId            Int
  periodeId            Int
  kpiDirectionId       Int?
  poids_dans_direction Float?
  cible                Float
  poids                Float
  statut               StatutKpi
  creeParId            Int
  catalogueKpi         CatalogueKpi @relation(fields: [catalogueKpiId], references: [id], onDelete: Cascade)
  service             Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  periode             Periode   @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  kpiDirection        KpiDirection? @relation(fields: [kpiDirectionId], references: [id], onDelete: SetNull)
  creePar             User      @relation(fields: [creeParId], references: [id], onDelete: Restrict)
  kpiEmployes         KpiEmploye[]
}

model KpiEmploye {
  id                    Int      @id @default(autoincrement())
  catalogueKpiId        Int
  employeId             Int
  assigneParId          Int
  kpiServiceId          Int?
  periodeId             Int
  cible                 Float
  poids                 Float
  statut                StatutKpiEmploye
  date_notification     DateTime?
  date_acceptation      DateTime?
  motif_contestation    String?
  reponse_contestation  String?
  catalogueKpi          CatalogueKpi @relation(fields: [catalogueKpiId], references: [id], onDelete: Cascade)
  employe               User     @relation("KpiEmployeEmploye", fields: [employeId], references: [id], onDelete: Cascade)
  assignePar            User     @relation("KpiEmployeAssignePar", fields: [assigneParId], references: [id], onDelete: Restrict)
  kpiService            KpiService? @relation(fields: [kpiServiceId], references: [id], onDelete: Cascade)
  periode               Periode  @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  saisiesMensuelles     SaisieMensuelle[]
  scorePeriodes         ScorePeriode[]
  @@index([employeId, periodeId, statut])
  @@index([kpiServiceId, periodeId])
}

// ---------------------------------------------------------------------------
// Saisies mensuelles
// ---------------------------------------------------------------------------

model SaisieMensuelle {
  id               Int      @id @default(autoincrement())
  kpiEmployeId     Int
  employeId         Int
  mois             Int
  annee            Int
  valeur_realisee   Float?
  commentaire      String?
  preuves          String?
  statut           StatutSaisie
  en_retard        Boolean  @default(false)
  soumis_le        DateTime?
  valideParId      Int?
  valide_le        DateTime?
  valeur_ajustee   Float?
  motif_ajustement String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  kpiEmploye       KpiEmploye @relation(fields: [kpiEmployeId], references: [id], onDelete: Cascade)
  employe          User     @relation(fields: [employeId], references: [id], onDelete: Cascade)
  validePar        User?    @relation("SaisieValidePar", fields: [valideParId], references: [id], onDelete: SetNull)
  @@unique([kpiEmployeId, mois, annee])
  @@index([kpiEmployeId, statut])
  @@index([employeId, mois, annee, statut])
}

model SaisieDirection {
  id               Int      @id @default(autoincrement())
  kpiDirectionId   Int
  mois             Int
  annee            Int
  valeur_prevue    Float?
  valeur_realisee  Float?
  commentaire      String?
  statut           StatutSaisie
  en_retard        Boolean  @default(false)
  soumis_le        DateTime?
  valideParId      Int?
  valide_le        DateTime?
  valeur_ajustee   Float?
  motif_ajustement String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  kpiDirection     KpiDirection @relation(fields: [kpiDirectionId], references: [id], onDelete: Cascade)
  validePar        User?    @relation("SaisieDirectionValidePar", fields: [valideParId], references: [id], onDelete: SetNull)
  @@unique([kpiDirectionId, mois, annee])
  @@index([kpiDirectionId, statut])
  @@index([mois, annee, statut])
}

// Période de saisie rouverte par le N+1 (saisie dépassée)
model SaisiePeriodeOuverte {
  id          Int      @id @default(autoincrement())
  employeId   Int
  mois        Int
  annee       Int
  ouvertParId Int
  createdAt   DateTime @default(now())
  employe     User     @relation("SaisiePeriodesOuvertesPour", fields: [employeId], references: [id], onDelete: Cascade)
  ouvertPar   User     @relation("SaisiePeriodesOuvertesPar", fields: [ouvertParId], references: [id], onDelete: Cascade)
  @@unique([employeId, mois, annee])
  @@index([employeId])
}

// ---------------------------------------------------------------------------
// Scores et consolidations
// ---------------------------------------------------------------------------

model ScorePeriode {
  id              Int      @id @default(autoincrement())
  kpiEmployeId    Int
  periodeId        Int
  valeur_agregee   Float
  taux_atteinte   Float
  calcule_le      DateTime
  kpiEmploye       KpiEmploye @relation(fields: [kpiEmployeId], references: [id], onDelete: Cascade)
  periode         Periode   @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  @@index([kpiEmployeId, periodeId])
}

model ScorePeriodeDirection {
  id              Int      @id @default(autoincrement())
  kpiDirectionId  Int
  periodeId       Int
  valeur_agregee  Float
  taux_atteinte   Float
  calcule_le      DateTime
  kpiDirection    KpiDirection @relation(fields: [kpiDirectionId], references: [id], onDelete: Cascade)
  periode         Periode      @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  @@index([kpiDirectionId, periodeId])
}

model ConsolidationService {
  id                        Int      @id @default(autoincrement())
  serviceId                 Int
  periodeId                 Int
  taux_atteinte_moyen       Float
  nb_employes_total         Int
  nb_employes_objectif_atteint Int
  calcule_le                DateTime
  service                   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  periode                   Periode   @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  @@index([serviceId, periodeId])
}

model ConsolidationDirection {
  id                  Int      @id @default(autoincrement())
  directionId         Int
  periodeId           Int
  taux_atteinte_moyen Float
  score_direction_kpis Float   @default(0)
  score_employes      Float    @default(0)
  calcule_le          DateTime
  direction           Direction @relation(fields: [directionId], references: [id], onDelete: Cascade)
  periode             Periode   @relation(fields: [periodeId], references: [id], onDelete: Cascade)
  @@index([directionId, periodeId])
}

// ---------------------------------------------------------------------------
// Grille de notation (paramétrable)
// ---------------------------------------------------------------------------

model NotationGrilleNiveau {
  id              Int      @id @default(autoincrement())
  niveau          String   @unique
  ordre           Int
  seuilMin        Float
  seuilMax        Float?
  notationLibelle String?
  appreciation    String
  commentaire     String
  updatedAt       DateTime @updatedAt

  @@index([ordre])
}

// ---------------------------------------------------------------------------
// Paramètres
// ---------------------------------------------------------------------------

model Parametre {
  id           Int      @id @default(autoincrement())
  cle          String   @unique
  valeur       String
  description  String?
  modifieParId Int
  modifie_le   DateTime
  modifiePar   User     @relation(fields: [modifieParId], references: [id], onDelete: Restrict)
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

model Notification {
  id            Int      @id @default(autoincrement())
  destinataireId Int
  type          TypeNotification
  titre         String
  message       String
  lu            Boolean  @default(false)
  lien          String?
  createdAt     DateTime @default(now())
  destinataire  User     @relation(fields: [destinataireId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Audit & Logs (purge après 1 an)
// ---------------------------------------------------------------------------

model AuditLog {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  userId      Int?
  action      String
  entityType  String?
  entityId    String?
  details     String?   @db.Text
  ip          String?
  userAgent   String?   @db.Text
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([createdAt])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// NextAuth (Prisma Adapter)
// ---------------------------------------------------------------------------

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  @@id([identifier, token])
}
